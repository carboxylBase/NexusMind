# ==========================================
# NexusMind 环境变量配置模板
# 复制此文件并重命名为 .env，然后填入真实的凭证
# ==========================================

# 1. 飞书配置
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-token-here

# 2. 大模型配置 (以豆包或通义千问为例)
LLM_API_KEY=your_llm_api_key_here
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3 # 示例：豆包 API 地址
LLM_MODEL_NAME=doubao-seed-2-0-pro-260215

# 3. GitHub 配置 (可选，如果不配置则只能访问公开仓库，且速率受限)
GITHUB_ACCESS_TOKEN=your_github_personal_access_token_here